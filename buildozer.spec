[app]
title = Zerogram
package.name = zerogram
package.domain = org.zerogram
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
requirements = python3,kivy,telethon
android.permissions = INTERNET,ACCESS_NETWORK_STATE
android.api = 30
android.minapi = 21
android.ndk = 25b
p4a.host_python = /usr/bin/python3

[buildozer]
log_level = 2
