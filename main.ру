from kivy.app import App
from kivy.uix.boxlayout import BoxLayout
from kivy.uix.button import Button
from kivy.uix.textinput import TextInput
from kivy.uix.label import Label
from telethon import TelegramClient
import threading
import asyncio

api_id = 2040
api_hash = 'b18441a1ff607e10a989891a5462e627'

class ZerogramApp(App):
    def build(self):
        self.title = 'Zerogram'
        self.client = TelegramClient('session', api_id, api_hash)
        layout = BoxLayout(orientation='vertical')
        self.info_label = Label(text='Zerogram')
        self.chat_label = Label(text='')
        self.msg_input = TextInput(hint_text='Сообщение в Избранное')
        btn = Button(text='Отправить')
        btn.bind(on_press=self.send_message)
        layout.add_widget(self.info_label)
        layout.add_widget(self.chat_label)
        layout.add_widget(self.msg_input)
        layout.add_widget(btn)
        threading.Thread(target=self.start_client).start()
        return layout

    def start_client(self):
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        loop.run_until_complete(self._async_start())

    async def _async_start(self):
        await self.client.start()
        self.info_label.text = 'Вход выполнен'
        dialogs = await self.client.get_dialogs(limit=10)
        names = '\n'.join([d.name for d in dialogs])
        self.chat_label.text = names

    def send_message(self, instance):
        text = self.msg_input.text
        if text:
            threading.Thread(target=self._send, args=(text,)).start()

    def _send(self, text):
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        loop.run_until_complete(self.client.send_message('me', text))

if __name__ == '__main__':
    ZerogramApp().run()
